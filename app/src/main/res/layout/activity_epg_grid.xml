<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/solplay_bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/solplay_orange"
        android:padding="16dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textColor="@color/solplay_white"
            android:textSize="22sp"
            android:paddingEnd="16dp"
            android:focusable="true"
            android:clickable="true" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Programme TV"
            android:textColor="@color/solplay_white"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- En-tête des heures : un espace vide aligné sur la colonne des chaînes,
         puis la frise horaire, elle-même défilable horizontalement et
         synchronisée avec chaque ligne (voir EpgGridActivity). -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal">

        <View
            android:layout_width="170dp"
            android:layout_height="match_parent"
            android:background="@color/solplay_gray" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/solplay_text_secondary" />

        <com.solplay.iptv.SyncHorizontalScrollView
            android:id="@+id/scrollHeader"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/solplay_gray"
            android:scrollbars="none"
            android:overScrollMode="never">

            <LinearLayout
                android:id="@+id/llHeaderTicks"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal" />

        </com.solplay.iptv.SyncHorizontalScrollView>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/solplay_text_secondary" />

    <TextView
        android:id="@+id/tvEpgEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="24dp"
        android:text="Aucune chaîne à afficher."
        android:textColor="@color/solplay_text_secondary"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerEpgRows"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
