<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/solplay_bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/solplay_orange"
        android:padding="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textColor="@color/solplay_white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnEpgGrid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📺 Grille TV"
            android:textColor="@color/solplay_white"
            android:textSize="13sp"
            android:textStyle="bold"
            android:padding="6dp"
            android:focusable="true"
            android:clickable="true" />

    </LinearLayout>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:tabIndicatorColor="@color/solplay_orange"
        app:tabSelectedTextColor="@color/solplay_orange"
        app:tabTextColor="@color/solplay_text_primary_dark" />

    <!-- focusable + focusableInTouchMode explicites : sur beaucoup de box
         Android TV, un EditText qui n'est pas explicitement déclaré
         focusable ne peut être atteint qu'au curseur souris/tactile, jamais
         à la télécommande (D-pad). Le nextFocusDown/Up fixe en plus un
         chemin de navigation déterministe (tabs -> recherche -> bouquets),
         car l'algorithme de recherche de focus "au plus proche" d'Android
         se trompe parfois entre une TabLayout, un EditText pleine largeur
         et une colonne de bouquets étroite juste en dessous. -->
    <EditText
        android:id="@+id/etSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="12dp"
        android:background="@color/solplay_gray"
        android:hint="Rechercher..."
        android:inputType="text"
        android:maxLines="1"
        android:padding="10dp"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:nextFocusUp="@id/tabLayout"
        android:nextFocusDown="@id/recyclerBouquets" />

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="24dp"
        android:text="Aucune chaîne trouvée."
        android:textColor="@color/solplay_text_secondary"
        android:visibility="gone" />

    <!-- Mise en page "maître-détail" : colonne de gauche = bouquets (catégories),
         colonne de droite = chaînes du bouquet sélectionné. Évite d'avoir à parcourir
         toutes les chaînes pour en trouver une : on choisit d'abord le bouquet. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerBouquets"
            android:layout_width="120dp"
            android:layout_height="match_parent"
            android:background="@color/solplay_gray"
            android:nextFocusUp="@id/etSearch" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/solplay_text_secondary" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerChannels"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:nextFocusUp="@id/etSearch" />

    </LinearLayout>

</LinearLayout>
