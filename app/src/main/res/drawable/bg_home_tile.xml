<?xml version="1.0" encoding="utf-8"?>
<!--
    Fond des tuiles de l'écran d'accueil (Live TV, Films, Séries...).
    Vert foncé bien visible quand la tuile a le focus (télécommande),
    au doigt, à la souris ou sélectionnée ; orange sinon.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/solplay_green_dark" />
            <corners android:radius="16dp" />
            <stroke android:width="3dp" android:color="@color/solplay_white" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/solplay_green_dark" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/solplay_green_dark" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/solplay_orange" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</selector>
